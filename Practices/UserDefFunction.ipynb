    "#wap to add num from 1 to 10:\n",
    "\n",
    "def add(i=1,s=0):\n",
    "    if i>10:\n",
    "        return s\n",
    "    s+=i\n",
    "    return add(i+1, s)\n",
    "print(add())"
   ],
